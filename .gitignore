# =============================================
# ENVIRONMENT — never commit real keys
# =============================================
.env
*.env
.env.*
!.env.example

# =============================================
# LOCAL USER DATA — never commit personal data
# =============================================

# Video library (all JSON in data/ except .gitkeep)
data/
!data/.gitkeep

# Any stray JSON files at root level
*.json
!package.json

# Transcript text files (manually uploaded/saved)
transcripts/
*.transcript.txt

# Exported files (Markdown, PDF, CSV exports — future V3)
exports/
*.export.md
*.export.pdf
*.export.csv

# User-generated notes files
notes/
*.notes.txt

# Any SQLite database (in case V2+ switches to DB)
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup

# =============================================
# STREAMLIT SECRETS — never commit real secrets
# =============================================
.streamlit/secrets.toml

# =============================================
# PYTHON
# =============================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
*.pyw
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
wheelhouse/

# =============================================
# VIRTUAL ENVIRONMENT
# =============================================
venv/
.venv/
env/
ENV/
.env.bak

# =============================================
# IDE & EDITOR
# =============================================
.vscode/
.idea/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.spyproject
.ropeproject

# =============================================
# TESTING & COVERAGE
# =============================================
.pytest_cache/
.cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc

# =============================================
# LOGS
# =============================================
*.log
logs/
log/

# =============================================
# OS FILES
# =============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# =============================================
# JUPYTER NOTEBOOKS (if used in future)
# =============================================
.ipynb_checkpoints/
*.ipynb

# =============================================
# TEMP / SCRATCH
# =============================================
tmp/
temp/
scratch/
*.tmp
*.temp
