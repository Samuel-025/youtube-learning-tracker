# YouTube Data API v3
# Get free key at: https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# AI Provider — pick at least one (all are optional; app works without them but summaries will be basic)
# Anthropic Claude (recommended): https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Groq (free tier, fast): https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# AI Provider to use (anthropic / openai / groq / none)
AI_PROVIDER=groq

# Storage path (default: data/videos.json)
STORAGE_PATH=data/videos.json
